# ─────────────────────────────────────────────────────────────
# TheFarm.com — Environment Variables
# Copy this file to `.env.local` and fill in what you need.
#
#   cp .env.local.example .env.local
#
# NOTHING here is required to run locally or on Vercel — email
# sign-in works out of the box. Add any OAuth block below and that
# provider's button appears on the login screen automatically.
# ─────────────────────────────────────────────────────────────

# Used to encrypt session cookies (JWT). REQUIRED in production.
# Generate one with:  openssl rand -base64 32
# A safe dev fallback is used automatically if you leave this blank.
NEXTAUTH_SECRET=

# The canonical URL of your app.
#   • Local dev: keep as-is.
#   • Vercel: set to your deployment URL, e.g. https://thefarm.com
#     (Vercel also exposes VERCEL_URL automatically for previews.)
NEXTAUTH_URL=http://localhost:3000

# ── Google ───────────────────────────────────────────────────
# https://console.cloud.google.com/apis/credentials
# Authorized redirect URI:
#   http://localhost:3000/api/auth/callback/google
#   https://YOUR_DOMAIN/api/auth/callback/google   (production)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── Apple (Sign in with Apple) ───────────────────────────────
# https://developer.apple.com/  (requires an Apple Developer account)
# CLIENT_ID = your Services ID. CLIENT_SECRET = a JWT you generate
# from your private key (.p8). See NextAuth's Apple provider docs.
# Redirect URI:  https://YOUR_DOMAIN/api/auth/callback/apple
# (Apple requires HTTPS — it won't accept http://localhost.)
APPLE_CLIENT_ID=
APPLE_CLIENT_SECRET=

# ── Facebook ─────────────────────────────────────────────────
# https://developers.facebook.com/apps  (add "Facebook Login")
# Valid OAuth redirect URI:
#   http://localhost:3000/api/auth/callback/facebook
#   https://YOUR_DOMAIN/api/auth/callback/facebook   (production)
FACEBOOK_CLIENT_ID=
FACEBOOK_CLIENT_SECRET=

# ── GitHub (optional — handy for developers) ─────────────────
# https://github.com/settings/developers  (New OAuth App)
# Authorization callback URL:
#   http://localhost:3000/api/auth/callback/github
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
